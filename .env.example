# SonarCloud
SONAR_TOKEN=your_sonarcloud_token
SONAR_WEBHOOK_SECRET=your_webhook_hmac_secret
SONAR_PROJECT_KEY=ameer-khan05_superset-aegis-demo

# GitHub
GITHUB_TOKEN=your_github_pat
GITHUB_REPO=ameer-khan05/superset-aegis-demo

# Devin API
DEVIN_API_KEY=your_devin_api_key
DEVIN_ORG_ID=org-your_org_id
DEVIN_USER_ID=user-your_user_id

# Jira Cloud (optional — leave blank to disable)
JIRA_BASE_URL=https://ameerkhan05.atlassian.net
JIRA_EMAIL=your_jira_email@example.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=KAN

# Aegis behaviour
AEGIS_MIN_SEVERITY=BLOCKER        # minimum severity threshold (BLOCKER, CRITICAL, MAJOR, MINOR, INFO)
AEGIS_ISSUE_TYPES=VULNERABILITY,BUG
AEGIS_MAX_ACU=15
AEGIS_POLL_INTERVAL=30
AEGIS_SESSION_TIMEOUT=1200
MAX_FINDINGS_PER_RUN=10           # hard cap on findings fetched from SonarCloud per run
MAX_SESSIONS_PER_RUN=5            # cap on Devin sessions launched per run (must be <= MAX_FINDINGS_PER_RUN)
